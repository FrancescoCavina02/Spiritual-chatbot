# ============================================================
# DATA DIRECTORIES
# Allow all files inside data/embeddings/ (ChromaDB snapshot).
# These negation rules MUST come before any broad deny rules
# (*.bin, *.sqlite3, etc.) that would otherwise override them.
# ============================================================
!data/
!data/embeddings/
!data/embeddings/**

# ChromaDB standalone databases (outside data/embeddings/) — ignore
chroma_db/

# Node.js / Frontend
node_modules/
.next/
out/
build/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Package manager locks
package-lock.json
yarn.lock
pnpm-lock.yaml

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Docker
*.dockerfile.bak

# OS
Thumbs.db
.DS_Store
*.swp

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Backups
*.bak
*.backup
*~

# ML Model files (large binaries)
# Scoped to /models/ — does NOT use *.bin globally so ChromaDB
# index files inside data/embeddings/ are never accidentally blocked.
/models/
*.safetensors
*.gguf
*.pt
*.pth

# API Keys and secrets
secrets/
*.key
*.pem
credentials.json

# Project specific
# (plan files are now tracked for documentation purposes)